# Gemini (client — used by Vite define)
GEMINI_API_KEY=

# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# App URL (used in emails and auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Sheets contact forms (server only — Apps Script web app)
GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_SHEETS_SECRET=replace-with-long-random-secret

# Resend - get API key from https://resend.com/api-keys
# Used by the admin panel "Send Test Email" button
RESEND_API_KEY=re_...your-resend-api-key...

# Sender address - use onboarding@resend.dev (free, sends only to your own Resend account email)
# OR use your own verified domain: YGPT EVENT <noreply@yourdomain.com>
RESEND_FROM_EMAIL=YGPT EVENT <onboarding@resend.dev>

# Telegram bot - create with @BotFather, then add these to Vercel Production
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
TELEGRAM_DISPATCH_SECRET=replace-with-a-random-dispatch-secret

# External API access (optional) — for scripts / non-browser clients
# Prefer Authorization: Bearer <supabase_access_token> for user-scoped routes
# Use X-API-Key for machine/admin routes (e.g. /api/drive/health)
EXTERNAL_API_KEY=replace-with-a-long-random-secret
